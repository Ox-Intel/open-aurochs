# Database
POSTGRES_DB=aurochs
POSTGRES_USER=aurochs
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://aurochs:your_secure_password_here@db:5432/aurochs

# Redis
REDIS_URL=redis://redis:6379/0

# Django settings
ENV=production
SECRET_KEY=your_very_long_random_secret_key_here
DJANGO_SETTINGS_MODULE=aurochs.settings

# Domains
AUROCHS_DOMAIN=your-domain.com
API_DOMAIN=api.your-domain.com
WEBAPP_DOMAIN=app.your-domain.com
AUROCHS_BASE_URL=https://your-domain.com
ADDITIONAL_ALLOWED_HOSTS=staging.your-domain.com,www.your-domain.com

# AWS (for S3 storage and SES email)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Email settings
DEFAULT_FROM_EMAIL=noreply@your-domain.com
SERVER_EMAIL=server@your-domain.com

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Rollbar (error tracking - optional)
ROLLBAR_ACCESS_TOKEN=your_rollbar_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Other API keys as needed
METAPHOR_API_KEY=your_metaphor_key_here
SERPAPI_API_KEY=your_serpapi_key_here